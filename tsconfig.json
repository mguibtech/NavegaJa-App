{
  "extends": "@react-native/typescript-config",
  "compilerOptions": {
    "types": ["jest"],
    "baseUrl": "./",
    "paths": {
      "@components": ["src/components"],
      "@components/*": ["src/components/*"],
      "@hooks": ["src/hooks"],
      "@hooks/*": ["src/hooks/*"],
      "@routes": ["src/routes"],
      "@routes/*": ["src/routes/*"],
      "@screens": ["src/screens"],
      "@screens/*": ["src/screens/*"],
      "@theme": ["src/theme"],
      "@theme/*": ["src/theme/*"],
      "@domain": ["src/domain"],
      "@domain/*": ["src/domain/*"],
      "@api": ["src/api"],
      "@api/*": ["src/api/*"],
      "@native": ["src/native"],
      "@native/*": ["src/native/*"],
      "@types": ["src/types"],
      "@types/*": ["src/types/*"],
      "@utils": ["src/utils"],
      "@utils/*": ["src/utils/*"],
      "@infra": ["src/infra"],
      "@infra/*": ["src/infra/*"],
      "@services": ["src/services"],
      "@services/*": ["src/services/*"],
      "@config": ["src/config"],
      "@config/*": ["src/config/*"],
      "@store": ["src/store"],
      "@store/*": ["src/store/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx"],
  "exclude": [
    "**/node_modules",
    "**/Pods",
    "**/__tests__/**",
    "**/*.test.ts",
    "**/*.test.tsx"
  ]
}
